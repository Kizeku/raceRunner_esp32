volatile uint32_t lastIsrMs  = 0;
volatile uint8_t roadLine = 0;
void IRAM_ATTR onBootPress(){
    uint32_t now = millis();
    if(now - lastIsrMs > 50){
        if(Pcar.road == 1)Pcar.road = 0;
        else Pcar.road = 1;
        lastIsrMs = now;
    }
}


volatile int x = 10;
const int y = 30;

volatile uint32_t lastUpdate = 0;

void loadScreen(uint16_t progress){
  uint32_t now = millis();
  if(now - lastUpdate >= 300){
    for(int i = 0 ; i < progress; i ++)
      display.drawPixel(x+i, y, WHITE);
    x += progress;
    lastUpdate = now;
    display.display();
  }
  
}

void frameUpdat(){
  static uint8_t i = 0;
  static uint32_t lastTashTime = 0;
  static bool trashActive= false;
  uint32_t now = millis();
  if((now-lastUpdate) >game_speed){
    display.clearDisplay();

    switch (i){
      case 0:
        display.drawBitmap(0,0,road,128,32,WHITE);
        display.drawBitmap(0,33,road5,128,32,WHITE);
      break;
      case 1:
        display.drawBitmap(0,0,road2,128,32,WHITE);
        display.drawBitmap(0,33,road4,128,32,WHITE);
      break;
      case 2:
        display.drawBitmap(0,0,road3,128,32,WHITE);
        display.drawBitmap(0,33,road3,128,32,WHITE);
      break;
      case 3:
        display.drawBitmap(0,0,road4,128,32,WHITE);
        display.drawBitmap(0,33,road2,128,32,WHITE);
      break;
      case 4:
        display.drawBitmap(0,0,road5,128,32,WHITE);
        display.drawBitmap(0,33,road,128,32,WHITE);
      break;
    }
    i++;
    if(i >4) i =0;
    display.drawBitmap(0,31,line,128,1,WHITE);

    if(Pcar.road == 0){
      display.drawBitmap(10,12,car,CAR_WIDTH,CAR_HEIGHT,WHITE);
    }else{
      display.drawBitmap(10,42,car,CAR_WIDTH,CAR_HEIGHT,WHITE);
    }

    if((now - lastTashTime) >= thingsOnRoad[0].spawnTime){// вывод мусора на попутной дороге
      lastTashTime = now;
      thingsOnRoad[0].active = true; 
    }
    if(thingsOnRoad[0].active){
      trashWorker();
    }
    
    // вывод машины на встречке
    
    
    display.display();

    lastUpdate = now;
  }
}

void trashWorker(){
   // пока так чистто проверить отрисовку и проигрыш 
  if(thingsOnRoad[0].active){
    display.drawBitmap(thingsOnRoad[0].place, 10, trashwood, TRASHWOOD_WIDTH, TRASHWOOD_HEIGHT, WHITE);
    if(thingsOnRoad[0].place == 0){ 
      thingsOnRoad[0].active    = false;
      thingsOnRoad[0].spawnTime = 2000 + (esp_random() % 3000);
      thingsOnRoad[0].hardLvl   = 2 + (esp_random() % 4); // случайная скорость движения 
    }
    thingsOnRoad[0].place -= thingsOnRoad[0].hardLvl;
  }
}

void loseCheck(bool & gameLose){
  if((thingsOnRoad[0].place <= 26) && (Pcar.road == 0)){
    gameLose = true;
  }
}

void setup() {
  Serial.begin(9600);

  pinMode(BOOT_PIN, INPUT_PULLUP);
  attachInterrupt(BOOT_PIN, onBootPress, FALLING);

    // SSD1306_SWITCHCAPVCC = generate display voltage from 3.3V internally
  if (!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("SSD1306 allocation failed"));
    for (;;);  // Don't proceed, loop forever
  }
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(WHITE);
  display.setCursor(10, 20);
  display.println("Loading");
  display.display();
}

void loop() {
  static bool gameLose  = false;
  static bool endScreen = true;
  if(x < 100){
    uint16_t prog = 5+ (esp_random() % 10);
    loadScreen(prog);
    gameStart = true;
  }else if (gameStart && !(gameLose)){
    frameUpdat();
    loseCheck(gameLose);
  }
  if(gameLose && endScreen){
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(WHITE);
    display.setCursor(24, 24);
    display.println("You Lose !");
    display.setCursor(24, 44);
    display.print("Your Time : ");
    display.println(millis()/1000);
    display.display();
    endScreen = false;
    delay(1000);
    ESP.restart();
  }
}
